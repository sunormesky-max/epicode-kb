# epicode-kb deployment environment configuration

# Backend
EPICODE_KB_LISTEN_ADDR=0.0.0.0:3000
EPICODE_KB_DATABASE_URL=/app/data/epicode_kb.db
EPICODE_KB_TANTIVY_PATH=/app/data/tantivy
EPICODE_KB_EMBED_MODEL=/app/models/all-MiniLM-L6-v2.onnx
EPICODE_KB_EMBED_DIMENSIONS=384
EPICODE_KB_UPLOAD_DIR=/app/data/uploads
EPICODE_KB_MAX_UPLOAD_SIZE=10485760

# DeepSeek LLM
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Logging
RUST_LOG=epicode_kb=info,tower_http=info
