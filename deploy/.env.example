# Production deployment environment

# Database
POSTGRES_PASSWORD=changeme

# JWT secrets (rotate in production)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# OIDC (optional)
# EPICODE_KB_OIDC_ISSUER=https://accounts.google.com
# EPICODE_KB_OIDC_CLIENT_ID=your-client-id
# EPICODE_KB_OIDC_CLIENT_SECRET=your-client-secret

# Embedding model
EPICODE_KB_EMBED_MODEL=/app/models/all-MiniLM-L6-v2.onnx
EPICODE_KB_EMBED_DIMENSIONS=384

# LLM
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Agent
EPICODE_KB_AGENT_WRITE_ENABLED=true
EPICODE_KB_API_KEY_SALT=change-me-salt
