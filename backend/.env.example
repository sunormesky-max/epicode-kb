# epicode-kb backend environment configuration

# Server
EPICODE_KB_LISTEN_ADDR=0.0.0.0:3000

# Database
EPICODE_KB_DATABASE_URL=data/epicode_kb.db

# Tantivy full-text index
EPICODE_KB_TANTIVY_PATH=data/tantivy

# ONNX embedding model
EPICODE_KB_EMBED_MODEL=models/all-MiniLM-L6-v2.onnx
EPICODE_KB_EMBED_DIMENSIONS=384

# File upload
EPICODE_KB_UPLOAD_DIR=data/uploads
EPICODE_KB_MAX_UPLOAD_SIZE=10485760

# DeepSeek LLM
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Logging
RUST_LOG=epicode_kb=info,tower_http=info

# --- v0.3.0: Conflict detection & health ---

# Semantic distance threshold for conflict detection (default: 0.3)
EPICODE_KB_CONFLICT_THRESHOLD=0.3

# LLM confidence threshold for contradiction flagging (default: 0.6)
EPICODE_KB_CONFLICT_LLM_CONFIDENCE=0.6

# Health scan interval in seconds (default: 86400 = daily)
EPICODE_KB_HEALTH_SCAN_INTERVAL=86400
