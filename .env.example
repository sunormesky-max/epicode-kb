# epicode-kb environment configuration
#
# Copy to `.env` and adjust. All variables are optional (defaults shown).
# Loaded by the backend via AppConfig::from_env() — see backend/src/config.rs.

# ── Server & storage ─────────────────────────────────────────────────────────
EPICODE_KB_LISTEN_ADDR=0.0.0.0:3000
EPICODE_KB_DATABASE_URL=data/epicode_kb.db
EPICODE_KB_TANTIVY_PATH=data/tantivy
EPICODE_KB_UPLOAD_DIR=data/uploads
# Max upload size in bytes (default 10 MiB).
EPICODE_KB_MAX_UPLOAD_SIZE=10485760

# ── Embeddings ───────────────────────────────────────────────────────────────
# When the ONNX model file is absent, a deterministic hash-based RandomEmbedder
# is used (no external dependency). Production: ship the real ONNX model.
EPICODE_KB_EMBED_MODEL=models/all-MiniLM-L6-v2.onnx
EPICODE_KB_EMBED_DIMENSIONS=384

# ── Document chunking ────────────────────────────────────────────────────────
EPICODE_KB_CHUNK_SIZE=512
EPICODE_KB_CHUNK_OVERLAP=64

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
# CHANGE THIS in production — it signs all access/refresh tokens.
EPICODE_KB_JWT_SECRET=change-me-in-production
EPICODE_KB_JWT_ACCESS_TTL=3600
EPICODE_KB_JWT_REFRESH_TTL=604800

# ── API keys ─────────────────────────────────────────────────────────────────
# Hex-encoded salt for hashing agent API keys. Leave unset to auto-generate.
# EPICODE_KB_API_KEY_SALT=
EPICODE_KB_AGENT_WRITE_ENABLED=true

# ── Conflict detection (P3) ──────────────────────────────────────────────────
# Semantic distance below which two memories are considered potentially
# contradictory (0.0 identical … 1.0 orthogonal). Default 0.3.
# EPICODE_KB_CONFLICT_THRESHOLD=0.3
# LLM verification confidence required to elevate a heuristic conflict into a
# confirmed contradiction (only used when an LLM is wired). Default 0.6.
# EPICODE_KB_CONFLICT_LLM_CONFIDENCE=0.6

# ── LLM (DeepSeek) — optional, powers AI proposals ───────────────────────────
# DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── OIDC SSO — optional ──────────────────────────────────────────────────────
# EPICODE_KB_OIDC_ISSUER_URL=
# EPICODE_KB_OIDC_CLIENT_ID=
# EPICODE_KB_OIDC_CLIENT_SECRET=
